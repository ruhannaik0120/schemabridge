# SchemaBridge local environment template.
# Copy this file to .env for local use. Never commit real credentials.

# Default connector used when the MCP server starts.
DB_TYPE=demo
DB_HOST=demo-local
DB_DATABASE=qa_demo
DB_USERNAME=
DB_PASSWORD=
DB_CONNECTION_OPTIONS={}
DB_TIMEOUT_SECONDS=30
DB_MAX_ROWS=500

# Optional approval-gated runtime profiles.
# Replace placeholder values only in your local .env file.
DB_ACTIVE_PROFILE=demo-local
DB_PROFILES_JSON={"demo-local":{"db_type":"demo","host":"demo-local","database":"qa_demo"},"postgres-local":{"db_type":"postgresql","host":"localhost","database":"<POSTGRES_DATABASE>","username":"<POSTGRES_USERNAME>","password":"<POSTGRES_PASSWORD>","connection_options":{"port":5432}},"snowflake-local":{"db_type":"snowflake","host":"<SNOWFLAKE_ACCOUNT_IDENTIFIER>","database":"<SNOWFLAKE_DATABASE>","username":"<SNOWFLAKE_USERNAME>","password":"<SNOWFLAKE_PASSWORD>","connection_options":{"warehouse":"<SNOWFLAKE_WAREHOUSE>","schema":"<SNOWFLAKE_SCHEMA>","role":"<SNOWFLAKE_ROLE>"}}}

LOG_LEVEL=INFO

# Set true only when smoke tests should contact a configured real database.
DB_SMOKE_TEST_CONNECT=false

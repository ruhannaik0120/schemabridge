# Active connector used when the MCP server starts.
DB_TYPE=demo
DB_HOST=demo-local
DB_DATABASE=qa_demo
DB_USERNAME=
DB_PASSWORD=
DB_CONNECTION_OPTIONS={}
DB_TIMEOUT_SECONDS=30
DB_MAX_ROWS=500

# Named profiles used for approval-gated runtime switching.
# These values are local demo credentials only. Put real secrets in clean_mcp/.env.
DB_ACTIVE_PROFILE=demo-local
DB_PROFILES_JSON={"demo-local":{"db_type":"demo","host":"demo-local","database":"qa_demo"},"postgres-local":{"db_type":"postgresql","host":"localhost","database":"qa_demo","username":"qa_user","password":"qa_password","connection_options":{"port":5432}},"mysql-local":{"db_type":"mysql","host":"localhost","database":"qa_demo","username":"qa_user","password":"qa_password","connection_options":{"port":3306}}}

LOG_LEVEL=INFO

# Set true only when the smoke test should contact the configured database.
# DB_SMOKE_TEST_CONNECT=true
